# Server
PORT=3001
NODE_ENV=production

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-in-production

# Database (MongoDB)
DATABASE_URL=mongodb://localhost:27017/vcc

# CORS - Frontend URL
CORS_ORIGIN=https://your-frontend.vercel.app

# AmzKeys (Optional - for auto card issuance)
AMZKEYS_BASE_URL=https://ymapi.amzkeys.com:15970
AMZKEYS_APP_ID=
AMZKEYS_APP_KEY=
AMZKEYS_PRIVATE_KEY=
AMZKEYS_AES_KEY=

# Admin Default Credentials (change in production!)
ADMIN_EMAIL=admin@visacard.com
ADMIN_PASSWORD=admin123456